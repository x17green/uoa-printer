generator client {
  provider        = "prisma-client"
  output          = "../lib/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id             Int             @id @default(autoincrement())
  staffNumber    String          @unique @db.VarChar(50)
  firstName      String          @db.VarChar(255)
  lastName       String          @db.VarChar(255)
  email          String?         @unique @db.VarChar(255)
  department     String?         @db.VarChar(255)
  position       String?         @db.VarChar(255)
  salary         Decimal?        @db.Decimal(15, 2)
  createdAt      DateTime        @default(now()) @db.Timestamp(6)
  updatedAt      DateTime        @default(now()) @updatedAt @db.Timestamp(6)
  payrollRecords PayrollRecord[]

  @@index([staffNumber], map: "idx_employee_staffnumber")
}

model PayrollRun {
  id               Int               @id @default(autoincrement())
  month            Int
  year             Int
  status           String            @default("PENDING") @db.VarChar(50)
  totalRecords     Int?              @default(0)
  processedRecords Int?              @default(0)
  errorRecords     Int?              @default(0)
  fileUrl          String?           @db.VarChar(255)
  notes            String?
  createdAt        DateTime          @default(now()) @db.Timestamp(6)
  updatedAt        DateTime          @default(now()) @db.Timestamp(6)
  records          PayrollRecord[]
  ValidationError  ValidationError[]

  @@unique([month, year])
  @@index([month, year], map: "idx_payrollrun_month_year")
}

model PayrollRecord {
  id                     Int                      @id @default(autoincrement())
  payrollRunId           Int
  employeeId             Int
  basicSalary            Decimal?                 @db.Decimal(15, 2)
  grossEarnings          Decimal?                 @default(0) @db.Decimal(15, 2)
  totalDeductions        Decimal?                 @default(0) @db.Decimal(15, 2)
  netPay                 Decimal?                 @default(0) @db.Decimal(15, 2)
  taxableIncome          Decimal?                 @db.Decimal(15, 2)
  incomeTax              Decimal?                 @default(0) @db.Decimal(15, 2)
  pensionContribution    Decimal?                 @default(0) @db.Decimal(15, 2)
  status                 String?                  @default("PENDING") @db.VarChar(50)
  notes                  String?
  createdAt              DateTime                 @default(now()) @db.Timestamp(6)
  updatedAt              DateTime                 @default(now()) @updatedAt @db.Timestamp(6)
  employee               Employee                 @relation(fields: [employeeId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  payrollRun             PayrollRun               @relation(fields: [payrollRunId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  PayrollRecordComponent PayrollRecordComponent[]
  ValidationError        ValidationError[]

  @@index([employeeId], map: "idx_payrollrecord_employee")
  @@index([payrollRunId], map: "idx_payrollrecord_run")
}

model PayrollComponent {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @db.VarChar(255)
  type                   String                   @db.VarChar(50)
  description            String?
  sheetName              String?                  @db.VarChar(255)
  isActive               Boolean?                 @default(true)
  createdAt              DateTime                 @default(now()) @db.Timestamp(6)
  updatedAt              DateTime                 @default(now()) @db.Timestamp(6)
  PayrollRecordComponent PayrollRecordComponent[]
}

model ValidationError {
  id              Int            @id @default(autoincrement())
  payrollRunId    Int
  payrollRecordId Int?
  staffNumber     String?        @db.VarChar(50)
  type            String         @db.VarChar(50)
  message         String
  severity        String?        @default("WARNING") @db.VarChar(50)
  isResolved      Boolean?       @default(false)
  createdAt       DateTime       @default(now()) @db.Timestamp(6)
  updatedAt       DateTime       @default(now()) @db.Timestamp(6)
  PayrollRecord   PayrollRecord? @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  PayrollRun      PayrollRun     @relation(fields: [payrollRunId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([payrollRecordId], map: "idx_validationerror_record")
  @@index([payrollRunId], map: "idx_validationerror_run")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PayrollRecordComponent {
  id               Int              @id @default(autoincrement())
  payrollRecordId  Int
  componentId      Int
  amount           Decimal          @db.Decimal(15, 2)
  createdAt        DateTime         @default(now()) @db.Timestamp(6)
  PayrollComponent PayrollComponent @relation(fields: [componentId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  PayrollRecord    PayrollRecord    @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([payrollRecordId, componentId])
}
